<!DOCTYPE html>
<html lang="en" style="background-color: <%= params.dig(:lookbook, :display, :bg_color) || "white" %>">
<head>
  <title>Components Preview</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= vite_javascript_tag 'application' %>
  <%= vite_stylesheet_tag 'application', media: 'all' %>
</head>
<body style="padding: 20px">
  <div style="margin-left: auto; margin-right: auto; max-width: <%= params.dig(:lookbook, :display, :max_width) || "100%" %>">
    <%= yield %>
  </div>
</body>
</html>
